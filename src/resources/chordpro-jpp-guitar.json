/**************** User defined chords ****************/

# chords: [ { name: Bes, frets: [ 1 1 3 3 3 1 ], fingers: [ 1 1 2 3 4 1 ] } ]

// *** PERSONALIZADO JPP: acordes no reconocidos por ChordPro ***
// frets: posiciones en el diagrama (0=cuerda al aire, -1=cuerda silenciada)
// fingers: digitación opcional (0-9)
// base: traste base (default 1)
// Para más info: https://www.chordpro.org/chordpro/chordpro-configuration-generic/#user-defined-chords-string-instruments
chords: [
  {
    // Am con nota añadida de 4ta — notas: A C D E
    // Cuerdas:  6    5    4    3    2    1
    //           Mi   La   Re   Sol  Si   Mi
    name    : "Am(add4)"
    base    : 1
    frets   : [  0   0    0    2    1    0 ]
    fingers : [  0   0    0    2    1    0 ]
  }
  { name : "Amadd4"  copy : "Am(add4)" }   // forma correcta
  { name : "AmAdd4"  copy : "Am(add4)" }   // variante mayúsculas
  { name : "*"  display : "*"  frets : [] fingers : [] }   // anotación — evita warning de [*]
  {
    // Am7 — override del built-in. Notas: A C E G
    // Cuerdas:  6    5    4    3    2    1
    //           Mi   La   Re   Sol  Si   Mi
    name    : "Am7"
    base    : 1
    frets   : [ -1   0    2    0    1    0 ]
    fingers : [  0   0    2    0    1    0 ]
  }
  {
    // Dsus2 — notas: D E A
    // Cuerdas:  6    5    4    3    2    1
    //           Mi   La   Re   Sol  Si   Mi
    name    : "Dsus2"
    base    : 1
    frets   : [ -1  -1   0    2    3    0 ]
    fingers : [  0   0   0    1    3    0 ]
  }
  {
    // D7sus4: D suspendido con 7ma — notas: D G A C
    // Cuerdas:  6    5    4    3    2    1
    name    : "D7sus4"
    base    : 1
    frets   : [ -1  -1   0    2    1    3 ]
    fingers : [  0   0   0    2    1    3 ]
  }
  {
    // F/G — notas: G F A C (bajo G)
    // Cuerdas:  6    5    4    3    2    1
    name    : "F/G"
    base    : 1
    frets   : [  3  -1   3    2    1    1 ]
    fingers : [  3   0   4    2    1    1 ]
  }
  {
    // F#/Ab — notas: G# F# A# C# (bajo Ab/G#)
    // Cuerdas:  6    5    4    3    2    1
    name    : "F#/Ab"
    base    : 1
    frets   : [  4  -1   4    3    2    2 ]
    fingers : [  3   0   4    2    1    1 ]
  }
  {
    // G/A — notas: A G B D (bajo A)
    // Cuerdas:  6    5    4    3    2    1
    name    : "G/A"
    base    : 2
    frets   : [  5  -1   5    4    3    3 ]
    fingers : [  3   0   4    2    1    1 ]
  }
]

