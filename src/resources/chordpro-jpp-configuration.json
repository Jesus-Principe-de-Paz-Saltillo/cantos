// =============================================================
// ChordPro — Archivo de configuración personalizado (JPP)
//
// Basado en el starter config oficial de ChordPro + documentación completa.
// Todos los parámetros están presentes con sus valores por defecto.
// Los que NO se han tocado están comentados con "# ".
// Los que SÍ están activos son las personalizaciones JPP.
//
// Documentación oficial:
//   PDF:      https://www.chordpro.org/chordpro/chordpro-configuration-pdf/
//   General:  https://www.chordpro.org/chordpro/chordpro-configuration-generic/
//   Fuentes:  https://www.chordpro.org/chordpro/chordpro-fonts/
//   Colores:  https://www.chordpro.org/chordpro/chordpro-colours/
// =============================================================

/**************** Para la GUI ****************/

// Tipo de configuración
config.type : config

// Título que aparece en los menús de la app
config.title : "JPP Config"

// Descripción
config.description : "Configuración personalizada JPP para ChordPro."

/**************** General settings ****************/

// Chords parsing strategy: strict (only known chords) or relaxed
settings.strict : true

// Titles flush: default center
# settings.titles : center

// Number of columns, default: 1
# settings.columns : 1

// Suppress empty chord lines. Command line: -a (--single-space)
# settings.suppress-empty-chords : true

// Suppress blank lyrics lines
# settings.suppress-empty-lyrics : true

// Suppress chords. Command line: -l (--lyrics-only)
# settings.lyrics-only : false

// Chords inline instead of above.
// May be a string containing pretext %s posttext.
// Defaults to "[%s]" if set to a value that does not contain "%s".
# settings.inline-chords : false

// Same, for annotations. Ignored unless inline-chords is set.
// Must be a string containing pretext %s posttext. Default is "%s".
# settings.inline-annotations : %s

// Chords under the lyrics
# settings.chords-under : false

// Transpose chords. 0 = no transpose
# settings.transpose : 0

// Force enharmonic when transposing (experimental)
# settings.enharmonic-transpose : true

// Transcode chords. "" = no transcode
# settings.transcode : ""

// Eliminate capo by transposing chords
# settings.decapo : false

// Strictness of parsing chord names
# settings.chordnames : strict

// Allow parsing of note names in []
# settings.notenames : false

// Always replace chords by their canonical form
# settings.chords-canonical : false

// If false, chorus labels are used as tags
# settings.choruslabels : true

// Substitute Unicode sharp/flats in chord names
# settings.truesf : false

// Substitute delta for maj7 in chord names
# settings.maj7delta : false

// Indent for wrapped lines. Actual indent is the stringwidth.
# settings.wrapindent : x

// Consider text flowed
# settings.flowtext : false

/**************** Metadata ****************/

// Append to known metadata items. Note that the first item must be
// "append" or it will overwrite instead of append...
metadata.keys : [ append author ccli footer ]

// If strict, only the known keys are allowed
# metadata.strict : true

// The separator is used to concatenate multiple values
# metadata.separator : "; "

// Split data on separator
# metadata.autosplit : true

/**************** Date formats. Format is a strftime template ****************/

# dates.today.format : "%A, %B %e, %Y"

/**************** User info ****************/

# user.name : ""
# user.fullname : ""

/**************** User defined chords ****************/

// Array of hashes, one per chord. Fields: name, base, frets, fingers, display
// Example: Alternative for Bes chord
# chords: [ { name: Bes, frets: [ 1 1 3 3 3 1 ], fingers: [ 1 1 2 3 4 1 ] } ]

// *** PERSONALIZADO JPP: acordes no reconocidos por ChordPro ***
// frets: posiciones en el diagrama (0=cuerda al aire, -1=cuerda silenciada)
// fingers: digitación opcional (0-9)
// base: traste base (default 1)
// Para más info: https://www.chordpro.org/chordpro/chordpro-configuration-generic/#user-defined-chords-string-instruments
chords: [
  {
    // Am con nota añadida de 4ta — notas: A C D E
    // Cuerdas:  6    5    4    3    2    1
    //           Mi   La   Re   Sol  Si   Mi
    name    : "Am(add4)"
    base    : 1
    frets   : [  0   0    0    2    1    0 ]  //  0 = cuerda al aire
    fingers : [  0   0    0    2    1    0 ]  //  0 = ningún dedo / cuerda al aire
  }
  { name : "Amadd4"  copy : "Am(add4)" }   // forma correcta
  { name : "AmAdd4"  copy : "Am(add4)" }   // variante mayúsculas
  {
    // Am7 — override del built-in. Notas: A C E G
    // Cuerdas:  6    5    4    3    2    1
    //           Mi   La   Re   Sol  Si   Mi
    name    : "Am7"
    base    : 1
    frets   : [ -1   0    2    0    1    0 ]
    fingers : [  0   0    2    0    1    0 ]
  }
  {
    // D7sus4: D suspendido con 7ma (Re-Sol-La-Do)
    // Posición: xx0213
    name    : "D7sus4"
    base    : 1
    frets   : [ -1 -1 0 2 1 3 ]
    fingers : [  0  0 0 2 1 3 ]
  }
]

/**************** Chord name formats ****************/

// Format string for rendering common chord names
# chord-formats.common : "%{root|%{}%{qual|%{}}%{ext|%{}}%{bass|/%{}}|%{name}}"

// Format string for rendering roman chord names
# chord-formats.roman : "%{root|%{}%{qual|<sup>%{}</sup>}%{ext|<sup>%{}</sup>}%{bass|/<sub>%{}</sub>}|%{name}}"

// Format string for rendering nashville chord names
# chord-formats.nashville : "%{root|%{}%{qual|<sup>%{}</sup>}%{ext|<sup>%{}</sup>}%{bass|/<sub>%{}</sub>}|%{name}}"

/**************** Chord diagrams (generic — qué acordes imprimir) ****************/

// "all": shows all chords / "user": user defined only / "none": suppresses all
# diagrams.show : all

// Sort diagrams by key. Default is order of appearance
# diagrams.sorted : false

// Chords that will not generate diagrams (e.g. trivial ones)
# diagrams.suppress : []     // lista de acordes que no generarán diagrama

