// Fonts — mapeo de elementos de salida a fuentes
// Los siguientes elementos heredan por defecto:
//   subtitle       --> text
//   chorus         --> text
//   comment        --> text
//   comment_italic --> chord
//   comment_box    --> chord
//   annotation     --> chord
//   toc            --> text
//   grid           --> chord
//   grid_margin    --> comment
//   footer         --> subtitle @ 60%
//   empty          --> text
//   diagram        --> comment
//   diagram_base   --> text (at a small size)

// Font for page titles. Default: "serif bold 14"
# pdf.fonts.title : "serif bold 14"

// Font for lyrics. Default: "serif 12"
# pdf.fonts.text : "serif 12"

// Font for chord names. Default: "sans italic 10"
// *** PERSONALIZADO JPP: acordes en rojo ***
// Para cambiar el tamaño, edita el número al final (ej: "sans italic 12")
pdf.fonts.chord.description : "sans italic 10"
pdf.fonts.chord.color : red

// Finger number color inside chord dots
# pdf.fonts.chordfingers.numbercolor : background

// Font for comment text. Default: "sans 12" with grey background
# pdf.fonts.comment : "sans 12; background=foreground-light"

// Font for italic comment text
# pdf.fonts.comment_italic : "Helvetica-Oblique 12"

// Font for boxed comment text
# pdf.fonts.comment_box : "sans 12; frame=1"

// Font for tabs
