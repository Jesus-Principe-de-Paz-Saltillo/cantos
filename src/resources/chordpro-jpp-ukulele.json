// Carga el preset oficial de ukulele (afinación GCEA y acordes built-in)
include : [ ukulele ]
instrument.type : "ukulele"

/**************** Acordes custom para ukulele ****************/

// Afinación: G C E A (cuerdas 4 3 2 1)
// frets:   [ str4  str3  str2  str1 ]
// fingers: [ str4  str3  str2  str1 ]
// 0 = cuerda al aire, -1 = cuerda silenciada

chords: [
  {
    // Am7 — todas las cuerdas al aire en ukulele estándar GCEA
    // Notas: G C E A = G A C E = Am7 ✓
    name    : "Am7"
    base    : 1
    frets   : [ 0  0  0  0 ]
    fingers : [ 0  0  0  0 ]
  }
  {
    // Am(add4) — notas: A C D E
    // str4(G) fret2=A | str3(C) fret2=D | str2(E) open=E | str1(A) open=A
    // ⚠️ Verifica esta posición antes de usarla
    name    : "Am(add4)"
    base    : 1
    frets   : [ 2  2  0  0 ]
    fingers : [ 1  2  0  0 ]
  }
  { name : "Amadd4"  copy : "Am(add4)" }   // forma correcta
  { name : "AmAdd4"  copy : "Am(add4)" }   // variante mayúsculas
  { name : "*"  display : "*"  frets : [] fingers : [] }   // anotación — evita warning de [*]
  {
    // F#m — notas: F# A C#
    // str4(G) fret2=A | str3(C) fret1=C# | str2(E) fret2=F# | str1(A) open=A
    name    : "F#m"
    base    : 1
    frets   : [ 2  1  2  0 ]
    fingers : [ 2  1  3  0 ]
  }
  {
    // C#m — notas: C# E G#
    // str4(G) fret1=G# | str3(C) fret1=C# | str2(E) open=E | str1(A) fret4=C#
    name    : "C#m"
    base    : 1
    frets   : [ 1  1  0  4 ]
    fingers : [ 1  2  0  4 ]
  }
  {
    // Dsus2 — notas: D E A
    // Cuerdas:  4    3    2    1
    //           G    C    E    A
    name    : "Dsus2"
    base    : 1
    frets   : [ 2    2    0    0 ]
    fingers : [ 2    3    0    0 ]
  }
  {
    // D7sus4 — notas: D G A C
    // str4(G) open=G | str3(C) fret2=D | str2(E) fret3=G | str1(A) fret2=B... 
    // Posición más común: 2 2 1 3
    // ⚠️ Verifica esta posición antes de usarla
    name    : "D7sus4"
    base    : 1
    frets   : [ 2  2  1  3 ]
    fingers : [ 2  3  1  4 ]
  }
  {
    // F/G — notas: G C F A (bajo G)
    name    : "F/G"
    base    : 1
    frets   : [ 0  0  1  0 ]
    fingers : [ 0  0  1  0 ]
  }
  {
    // F#/Ab — notas: G# C# F# A# (bajo Ab/G#)
    name    : "F#/Ab"
    base    : 1
    frets   : [ 1  1  2  1 ]
    fingers : [ 1  1  2  1 ]
  }
  {
    // G/A — notas: A D G B (bajo A)
    name    : "G/A"
    base    : 1
    frets   : [ 2  2  3  2 ]
    fingers : [ 1  1  2  1 ]
  }
]

